---
import "../styles/global.css";

const {
  title = "Lunemint ✦ Creative Design Desk",
  description = "A dreamy, scrapbook-inspired portfolio and commission site for Lunemint.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="shortcut icon" href="public/fave-icon.svg" />

    <title>{title}</title>
  </head>

  <body>
    <main class="site-shell">
      <div class="site-inner">
        <slot />
      </div>
    </main>
  </body>
</html>
