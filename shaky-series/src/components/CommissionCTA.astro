<section id="request" class="commission-cta">
  <p class="section-kicker">Let’s work together</p>
  <h2>Ready to start your Commission<span class="question-mark">?</span></h2>
  <p>Click that button if you’re ready for some lunemint action!~</p>
  <button class="lunemint-button" id="open-commission" type="button">
    Request a Commission<span class="question-mark">?</span>
  </button>
</section>

<dialog class="commission-modal" id="commission-modal">
  <form method="dialog" class="modal-card">
    <button class="close-button" value="close" aria-label="Close form">×</button
    >

    <h3>Commission Request</h3>
    <p>
      Form layout placeholder. We’ll replace this once you send the form sample.
    </p>

    <label>
      Name
      <input type="text" placeholder="Your name" />
    </label>

    <label>
      Project type
      <input
        type="text"
        placeholder="Presentation, Canva graphic, resume, etc."
      />
    </label>

    <label>
      Notes
      <textarea placeholder="Tell me about your idea"></textarea>
    </label>

    <button class="lunemint-button" type="submit">Submit Request ✦</button>
  </form>
</dialog>

<script>
  const openButton = document.querySelector("#open-commission");
  const modal = document.querySelector("#commission-modal");

  openButton?.addEventListener("click", () => {
    if (modal instanceof HTMLDialogElement) {
      document.body.classList.add("modal-open");
      modal.showModal();
    }
  });

  modal?.addEventListener("close", () => {
    document.body.classList.remove("modal-open");
  });
</script>

