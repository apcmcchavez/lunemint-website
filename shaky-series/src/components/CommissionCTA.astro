<section id="request" class="commission-cta">
  <p class="section-kicker">Let’s work together</p>
  <h2>Ready to start your Commission<span class="question-mark">?</span></h2>
  <p>Click that button if you’re ready for some lunemint action!~</p>

  <button class="lunemint-button" id="open-commission" type="button">
    Request a Commission<span class="question-mark">?</span>
  </button>
</section>

<dialog class="commission-modal" id="commission-modal">
  <div class="commission-modal-inner">
    <button
      class="modal-close-btn"
      id="close-commission"
      type="button"
      aria-label="Close commission form"
    >
      ×
    </button>

    <form class="cm-form-panel" id="commission-form">
      <span class="cm-eyebrow">✦ Commission Desk</span>

      <h3 class="cm-title">New Commission</h3>
      <p class="cm-subtitle">
        No payment yet — this form is only for request review and quotation ✦
      </p>

      <div class="cm-row">
        <label class="cm-field">
          <span class="cm-label">Your Name</span>
          <input
            class="cm-input"
            type="text"
            id="c-name"
            name="name"
            placeholder="Enter your name"
            required
          />
        </label>

        <label class="cm-field">
          <span class="cm-label">Email</span>
          <input
            class="cm-input"
            type="email"
            id="c-email"
            name="email"
            placeholder="Your email"
            required
          />
        </label>
      </div>

      <div class="cm-row">
        <label class="cm-field">
          <span class="cm-label">Client Location</span>
          <select class="cm-input" id="c-location" name="location" required>
            <option value="">Select location</option>
            <option>United States</option>
            <option>Philippines</option>
            <option>Other / International</option>
          </select>
        </label>

        <label class="cm-field">
          <span class="cm-label">Payment Preference</span>
          <select class="cm-input" id="c-payment" name="payment">
            <option value="">Select payment option</option>
            <option>Cashapp / US</option>
            <option>GCash / Philippines</option>
            <option>To be discussed</option>
          </select>
        </label>
      </div>

      <div class="cm-row">
        <label class="cm-field">
          <span class="cm-label">Project Type</span>
          <select class="cm-input" id="c-type" name="type" required>
            <option value="">Select a service</option>
            <option>Canva Graphic</option>
            <option>Presentation Deck</option>
            <option>Resume Template</option>
            <option>Patterned Design</option>
            <option>Certificate Template</option>
            <option>Invitation / Event Design</option>
            <option>Other Custom Design</option>
          </select>
        </label>

        <label class="cm-field">
          <span class="cm-label">Deadline</span>
          <input class="cm-input" type="date" id="c-deadline" name="deadline" />
        </label>
      </div>

      <div class="cm-row">
        <label class="cm-field">
          <span class="cm-label">Budget Range</span>
          <select class="cm-input" id="c-budget" name="budget">
            <option value="">Select range</option>
            <option>Under ₱200 / under $5</option>
            <option>₱200–₱500 / around $5–$10</option>
            <option>₱500–₱1,000 / around $10–$20</option>
            <option>₱1,000+ / $20+</option>
            <option>Still unsure</option>
          </select>
        </label>

        <label class="cm-field">
          <span class="cm-label">Request Purpose</span>
          <select class="cm-input" id="c-purpose" name="purpose">
            <option>Personal use</option>
            <option>School / academic</option>
            <option>Organization / event</option>
            <option>Small business / brand</option>
            <option>Other</option>
          </select>
        </label>
      </div>

      <label class="cm-field full">
        <span class="cm-label">Reference Link</span>
        <input
          class="cm-input"
          type="url"
          id="c-reference"
          name="reference"
          placeholder="Paste Canva, Pinterest, Drive, or inspo link if any"
        />
      </label>

      <label class="cm-field full">
        <span class="cm-label">Project Details</span>
        <textarea
          class="cm-input cm-textarea"
          id="c-details"
          name="details"
          placeholder="Tell me about your project — theme, purpose, size, colors, deadline notes, references..."
          required></textarea>
      </label>

      <p class="cm-note">
        For ready-made templates, please check my Gumroad or Raket.ph instead.
        Custom requests are reviewed first before pricing is finalized.
      </p>

      <button class="cm-submit" type="submit">Submit Request ✦</button>
    </form>

    <aside class="cm-receipt-panel">
      <div class="cm-receipt-content">
        <div class="receipt-card">
          <h4>Starting Rates</h4>
          <p>
            Base prices are in PHP. USD/Cash App quotes are confirmed after I
            review the request.
          </p>

          <div class="receipt-rate-row">
            <span>Canva Graphics</span>
            <strong>from ₱150</strong>
          </div>

          <div class="receipt-rate-row">
            <span>Presentations</span>
            <strong>from ₱300</strong>
          </div>

          <div class="receipt-rate-row">
            <span>Resume Design</span>
            <strong>from ₱200</strong>
          </div>

          <div class="receipt-rate-row">
            <span>Patterned Designs</span>
            <strong>from ₱250</strong>
          </div>

          <div class="receipt-rate-row">
            <span>Certificates</span>
            <strong>from ₱180</strong>
          </div>
        </div>

        <div class="receipt-card mini-card">
          <h4>Where to Buy</h4>
          <p>
            Gumroad and Raket.ph are for digital products. This form is for
            custom commissions.
          </p>

          <div class="summary-line">
            <span>US Payment</span>
            <strong>Cash App</strong>
          </div>

          <div class="summary-line">
            <span>PH Payment</span>
            <strong>GCash</strong>
          </div>
        </div>

        <div class="receipt-card">
          <h4>What happens next?</h4>

          <div class="receipt-step-row">
            <span class="receipt-step-num">1</span>
            <p>Submit your request.</p>
          </div>

          <div class="receipt-step-row">
            <span class="receipt-step-num">2</span>
            <p>I review the details and confirm if I can take it.</p>
          </div>

          <div class="receipt-step-row">
            <span class="receipt-step-num">3</span>
            <p>You receive the quote, timeline, and payment instructions.</p>
          </div>

          <div class="receipt-step-row">
            <span class="receipt-step-num">4</span>
            <p>Design work begins after confirmation.</p>
          </div>
        </div>
      </div>

      <div class="receipt-barcode">
        <div class="receipt-barcode-bars" id="commission-barcode"></div>
        <div class="receipt-barcode-text">
          Lunemint Designs ✦ Commission Desk
        </div>
      </div>
    </aside>
  </div>
</dialog>

<script>
  const openButton =
    document.querySelector<HTMLButtonElement>("#open-commission");
  const closeButton =
    document.querySelector<HTMLButtonElement>("#close-commission");
  const modal = document.querySelector<HTMLDialogElement>("#commission-modal");
  const form = document.querySelector<HTMLFormElement>("#commission-form");

  const nameInput = document.querySelector<HTMLInputElement>("#c-name");
  const emailInput = document.querySelector<HTMLInputElement>("#c-email");
  const locationInput =
    document.querySelector<HTMLSelectElement>("#c-location");
  const paymentInput = document.querySelector<HTMLSelectElement>("#c-payment");
  const typeInput = document.querySelector<HTMLSelectElement>("#c-type");
  const budgetInput = document.querySelector<HTMLSelectElement>("#c-budget");
  const deadlineInput = document.querySelector<HTMLInputElement>("#c-deadline");
  const purposeInput = document.querySelector<HTMLSelectElement>("#c-purpose");
  const referenceInput =
    document.querySelector<HTMLInputElement>("#c-reference");
  const detailsInput =
    document.querySelector<HTMLTextAreaElement>("#c-details");
  const barcode = document.querySelector<HTMLElement>("#commission-barcode");

  function generateBarcode(): void {
    if (!barcode) return;

    barcode.innerHTML = "";

    const heights = [
      28, 42, 20, 36, 48, 24, 40, 31, 46, 22, 34, 44, 26, 38, 50, 30, 42, 24,
      36, 48, 28, 40, 22, 34,
    ];

    heights.forEach((height) => {
      const bar = document.createElement("span");
      bar.style.height = `${height}px`;
      barcode.appendChild(bar);
    });
  }

  function formatDate(value: string): string {
    if (!value) return "Flexible";

    const date = new Date(`${value}T00:00:00`);

    return date.toLocaleDateString("en-US", {
      month: "short",
      day: "numeric",
      year: "numeric",
    });
  }

  function openCommissionModal(): void {
    if (!modal) return;

    document.body.classList.add("modal-open");
    modal.showModal();
    generateBarcode();
  }

  function closeCommissionModal(): void {
    if (!modal) return;

    modal.close();
    document.body.classList.remove("modal-open");
  }

  openButton?.addEventListener("click", openCommissionModal);
  closeButton?.addEventListener("click", closeCommissionModal);

  modal?.addEventListener("click", (event: MouseEvent) => {
    if (event.target === modal) {
      closeCommissionModal();
    }
  });

  modal?.addEventListener("close", () => {
    document.body.classList.remove("modal-open");
  });

  form?.addEventListener("submit", (event: SubmitEvent) => {
    event.preventDefault();

    const name = nameInput?.value.trim() || "";
    const email = emailInput?.value.trim() || "";
    const location = locationInput?.value || "";
    const payment = paymentInput?.value || "Not specified";
    const type = typeInput?.value || "";
    const budget = budgetInput?.value || "Not specified";
    const deadline = deadlineInput?.value
      ? formatDate(deadlineInput.value)
      : "Flexible";
    const purpose = purposeInput?.value || "Not specified";
    const reference = referenceInput?.value.trim() || "None";
    const details = detailsInput?.value.trim() || "";

    if (!name || !email || !location || !type || !details) {
      alert(
        "Please fill in your name, email, location, project type, and project details before submitting ✦",
      );
      return;
    }

    const subject = encodeURIComponent(`New Commission Request from ${name}`);
    const body = encodeURIComponent(`New Commission Request ✦

Name: ${name}
Email: ${email}
Client Location: ${location}
Payment Preference: ${payment}
Project Type: ${type}
Budget Range: ${budget}
Deadline: ${deadline}
Request Purpose: ${purpose}
Reference Link: ${reference}

Project Details:
${details}

---
Sent from the Lunemint commission form.`);

    window.location.href = `mailto:lunemint.designs@gmail.com?subject=${subject}&body=${body}`;

    closeCommissionModal();

    window.setTimeout(() => {
      alert(
        `Thank you, ${name}! ✦ Your email app should open with your commission request ready to send.`,
      );
    }, 250);
  });
</script>

