---

<section class="reviews">
  <div class="reviews-paper">
    <img
      class="torn torn-top"
      src="/images/reviews/customer-reviews-torn-paper-top.webp"
      alt=""
      aria-hidden="true"
    />

    <div class="reviews-content">
      <div class="reviews-heading">
        <p>Check what others say</p>
        <h2>Customer Reviews</h2>
      </div>

      <div class="review-board">
        <img
          class="review-grid"
          src="/images/reviews/customer-reviews-grid.png"
          alt=""
          aria-hidden="true"
        />

        {
          reviewSets.map((set, setIndex) => (
            <div class={`review-set ${setIndex === 0 ? "active" : "inactive"}`}>
              {set.map((review) => (
                <article
                  class="review-tag"
                  style={`--x:${review.x}; --y:${review.y}; --base-rotate:${review.rotate}deg; --random-rotate:0deg; --tag:url('/images/reviews/customer-review-tag-${review.tag}.svg');`}
                >
                  <div class="review-copy">
                    <p>{review.quote}</p>
                    <strong>{review.alias}</strong>
                  </div>
                </article>
              ))}
            </div>
          ))
        }
      </div>

      <div class="review-dots" aria-hidden="true">
        {
          reviewSets.map((_, setIndex) => (
            <span class={`review-dot ${setIndex === 0 ? "active" : ""}`} />
          ))
        }
      </div>
    </div>

    <img
      class="torn torn-bottom"
      src="/images/reviews/customer-reviews-torn-paper-bottom.webp"
      alt=""
      aria-hidden="true"
    />
  </div>
</section>

<style>
  .reviews {
    background: #f8faf0;
    overflow: visible;
    position: relative;
  }

  .reviews-paper {
    background-color: #efe3ca;
    background-image: url("/images/reviews/crumpled-paper-bg.webp");
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: visible;
    padding-top: 120px;
    padding-bottom: 150px;
  }

  .torn {
    width: 100%;
    height: auto;
    display: block;
    position: absolute;
    left: 0;
    z-index: 5;
    pointer-events: none;
  }

  .torn.torn-top {
    top: -58px;
  }

  .torn.torn-bottom {
    bottom: -58px;
  }

  .reviews-content {
    position: relative;
    z-index: 2;
    padding: 72px 1.5rem 96px;
  }

  .reviews-heading {
    text-align: center;
    margin-bottom: 54px;
  }

  .reviews-heading p {
    margin: 0 0 6px;
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.4vw, 1.45rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a330a5;
  }

  .reviews-heading h2 {
    margin: 0;
    font-family: var(--font-gladiola);
    font-size: clamp(4.4rem, 5.4vw, 56px);
    font-style: italic;
    font-weight: 800;
    color: #290087;
    line-height: 1;
  }

  .review-board {
    width: min(1540px, 86vw);
    margin: 0 auto;
    position: relative;
    overflow: visible;
    min-height: 340px;
  }

  .review-grid {
    width: 100%;
    height: auto;
    display: block;
  }

  .review-set {
    position: absolute;
    inset: 0;
    transition:
      opacity 900ms ease,
      transform 900ms ease;
  }

  .review-set.inactive {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.98);
  }

  .review-set.active {
    opacity: 1;
    pointer-events: auto;
    transform: scale(1);
  }

  .review-tag {
    position: absolute;
    left: var(--x);
    top: var(--y);
    z-index: 3;

    width: clamp(320px, 24vw, 420px);
    min-height: clamp(140px, 9vw, 170px);

    display: flex;
    align-items: center;
    justify-content: center;

    transform: rotate(calc(var(--base-rotate) + var(--random-rotate)));
    transform-origin: center;
    transition: transform 900ms ease;
    animation: reviewFloat 12s ease-in-out infinite alternate;

    text-align: center;
    box-sizing: border-box;
  }

  .review-tag::before {
    content: "";
    position: absolute;
    inset: -54% -38%;
    background-image: var(--tag);
    background-size: 100% 100%;
    background-position: center;
    background-repeat: no-repeat;
    z-index: -1;
    pointer-events: none;
  }

  .review-copy {
    width: 100%;
    max-width: 280px;
    margin: 0 auto;
    padding: 0.95rem 1rem 0.95rem;
    background: #f7ffea;
    border-radius: 20px;
    box-shadow: 0 16px 30px rgba(0, 0, 0, 0.08);
    position: relative;
    z-index: 1;
  }

  .review-copy p {
    margin: 0 0 0.8rem;
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 1.3vw, 1.5rem);
    line-height: 1.4;
    font-style: italic;
    font-weight: 400;
    color: #4f3a8f;
  }

  .review-copy strong {
    display: block;
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 0.9vw, 1rem);
    line-height: 1.15;
    font-weight: 800;
    color: #ffcf67;
  }

  .review-dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 30px;
  }

  .review-dot {
    width: 12px;
    height: 12px;
    border-radius: 999px;
    background: rgba(41, 0, 135, 0.24);
    transition:
      background 260ms ease,
      transform 260ms ease;
  }

  .review-dot.active {
    background: #a330a5;
    transform: scale(1.2);
  }

  @keyframes reviewFloat {
    0% {
      transform: translateY(0px)
        rotate(calc(var(--base-rotate) + var(--random-rotate)));
    }
    100% {
      transform: translateY(-12px)
        rotate(calc(var(--base-rotate) + var(--random-rotate)));
    }
  }

  @media (max-width: 1200px) {
    .review-board {
      width: min(1080px, 86vw);
    }

    .review-tag {
      width: clamp(260px, 25vw, 330px);
      min-height: clamp(105px, 10vw, 140px);
    }

    .review-tag::before {
      inset: -48% -36%;
    }

    .review-copy {
      max-width: 250px;
    }

    .review-copy p {
      font-size: clamp(0.85rem, 1.35vw, 1.05rem);
    }

    .review-copy strong {
      font-size: clamp(0.62rem, 0.9vw, 0.78rem);
    }
  }

  @media (max-width: 850px) {
    .reviews-paper {
      padding-top: 78px;
      padding-bottom: 92px;
    }

    .torn.torn-top {
      top: -34px;
    }

    .torn.torn-bottom {
      bottom: -34px;
    }

    .reviews-content {
      padding: 64px 1.25rem 72px;
    }

    .reviews-heading {
      margin-bottom: 34px;
    }

    .reviews-heading h2 {
      font-size: clamp(3.8rem, 15vw, 5.8rem);
    }

    .review-board {
      display: grid;
      gap: 2rem;
      width: min(430px, 92vw);
    }

    .review-grid {
      display: none;
    }

    .review-tag {
      position: relative;
      left: auto;
      top: auto;
      width: min(310px, 76vw);
      min-height: 130px;
      margin: 0 auto;
    }

    .review-tag::before {
      inset: -44% -34%;
    }

    .review-copy {
      max-width: 250px;
    }

    .review-copy p {
      font-size: clamp(0.95rem, 4.2vw, 1.2rem);
    }

    .review-copy strong {
      font-size: clamp(0.7rem, 3vw, 0.85rem);
    }
  }
</style>

<script is:inline>
  function applyRandomReviewRotations() {
    document.querySelectorAll(".review-tag").forEach((tag) => {
      const random = (Math.random() * 5 - 2.5).toFixed(2);
      tag.style.setProperty("--random-rotate", `${random}deg`);
    });
  }

  function updateReviewVisibility() {
    const sets = document.querySelectorAll(".review-set");
    const dots = document.querySelectorAll(".review-dot");
    let activeIndex = 0;

    function showSet(index) {
      sets.forEach((set, i) => {
        set.classList.toggle("active", i === index);
        set.classList.toggle("inactive", i !== index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle("active", i === index);
      });
    }

    showSet(activeIndex);

    setInterval(() => {
      activeIndex = (activeIndex + 1) % sets.length;
      showSet(activeIndex);
    }, 6500);
  }

  applyRandomReviewRotations();
  setInterval(applyRandomReviewRotations, 3500);
  window.addEventListener("load", updateReviewVisibility);
</script>
