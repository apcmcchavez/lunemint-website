---

<section class="reviews">
  <div class="reviews-paper">
    <img
      class="torn torn-top"
      src="/images/reviews/customer-reviews-torn-paper-top.webp"
      alt=""
      aria-hidden="true"
    />

    <div class="reviews-content">
      <div class="reviews-heading">
        <p>Check what others say</p>
        <h2>Customer Reviews</h2>
      </div>

      <div class="review-board">
        <img
          class="review-grid"
          src="/images/reviews/customer-reviews-grid.png"
          alt=""
          aria-hidden="true"
        />

        {
          reviewSets.map((set, setIndex) => (
            <div
              class={`review-set ${setIndex === 0 ? "active" : ""}`}
              data-review-set
            >
              {set.map((review) => (
                <article
                  class="review-tag"
                  style={`--x:${review.x}; --y:${review.y}; --rotate:${review.rotate}deg; --tag:url('/images/reviews/customer-review-tag-${review.tag}.svg');`}
                >
                  <div class="review-copy">
                    <p>{review.quote}</p>
                    <strong>{review.alias}</strong>
                  </div>
                </article>
              ))}
            </div>
          ))
        }
      </div>

      <div class="review-dots" aria-label="Review pages">
        {
          reviewSets.map((_, setIndex) => (
            <button
              class={`review-dot ${setIndex === 0 ? "active" : ""}`}
              type="button"
              aria-label={`Show review set ${setIndex + 1}`}
              data-review-dot={setIndex}
            />
          ))
        }
      </div>
    </div>

    <img
      class="torn torn-bottom"
      src="/images/reviews/customer-reviews-torn-paper-bottom.webp"
      alt=""
      aria-hidden="true"
    />
  </div>
</section>

<style>
  .reviews {
    background: #f8faf0;
    overflow: visible;
    position: relative;
  }

  .reviews-paper {
    background-color: #efe3ca;
    background-image: url("/images/reviews/crumpled-paper-bg.webp");
    background-size: cover;
    background-position: center;
    position: relative;
    overflow: visible;
    padding-top: 112px;
    padding-bottom: 142px;
  }

  .torn {
    width: 100%;
    height: auto;
    display: block;
    position: absolute;
    left: 0;
    z-index: 5;
    pointer-events: none;
  }

  .torn.torn-top {
    top: -58px;
  }

  .torn.torn-bottom {
    bottom: -58px;
  }

  .reviews-content {
    position: relative;
    z-index: 2;
    padding: 72px 1.5rem 96px;
  }

  .reviews-heading {
    text-align: center;
    margin-bottom: 54px;
  }

  .reviews-heading p {
    margin: 0 0 8px;
    font-family: var(--font-body);
    font-size: clamp(1.1rem, 1.35vw, 1.45rem);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #a330a5;
  }

  .reviews-heading h2 {
    margin: 0;
    font-family: var(--font-gladiola);
    font-size: clamp(4.8rem, 6.8vw, 7.8rem);
    font-style: italic;
    font-weight: 800;
    color: #290087;
    line-height: 0.95;
  }

  .review-board {
    width: min(1430px, 86vw);
    margin: 0 auto;
    position: relative;
    overflow: visible;
  }

  .review-grid {
    width: 100%;
    height: auto;
    display: block;
  }

  .review-set {
    position: absolute;
    inset: 0;
    display: none;
  }

  .review-set.active {
    display: block;
  }

  .review-tag {
    position: absolute;
    left: var(--x);
    top: var(--y);
    z-index: 3;

    width: clamp(335px, 27vw, 450px);
    aspect-ratio: 485.5 / 273.7;

    display: flex;
    align-items: center;
    justify-content: center;

    background-image: var(--tag);
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;

    transform: rotate(var(--rotate));
    transform-origin: center;

    text-align: center;
    box-sizing: border-box;
  }

  .review-copy {
    width: 82%;
    height: 68%;
    max-width: none;

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;

    margin: 0;
    padding: 0 0.75rem;
    box-sizing: border-box;

    background: transparent;
    border-radius: 0;
    box-shadow: none;
  }

  .review-copy p {
    width: 100%;
    margin: 0 0 0.55rem;

    font-family: var(--font-body);
    font-size: clamp(1rem, 1.16vw, 1.28rem);
    line-height: 1.12;
    font-style: italic;
    font-weight: 400;

    color: #8e7cca;
  }

  .review-copy strong {
    display: block;
    width: 100%;

    font-family: var(--font-body);
    font-size: clamp(0.7rem, 0.78vw, 0.86rem);
    line-height: 1.08;
    font-weight: 800;

    color: #ffcf67;
  }

  .review-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 34px;
  }

  .review-dot {
    width: 13px;
    height: 13px;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: rgba(41, 0, 135, 0.25);
    cursor: pointer;
    transition:
      background 260ms ease,
      transform 260ms ease;
  }

  .review-dot.active {
    background: #a330a5;
    transform: scale(1.22);
  }

  @media (max-width: 1200px) {
    .review-board {
  width: min(1080px, 86vw);
}

.review-tag {
  width: clamp(270px, 27vw, 350px);
}

.review-copy {
  width: 82%;
  height: 68%;
  padding: 0 0.55rem;
}

.review-copy p {
  font-size: clamp(0.78rem, 1.12vw, 0.96rem);
}

.review-copy strong {
  font-size: clamp(0.55rem, 0.72vw, 0.68rem);
}

  @media (max-width: 850px) {
    .reviews-paper {
      padding-top: 78px;
      padding-bottom: 92px;
    }

    .torn.torn-top {
      top: -34px;
    }

    .torn.torn-bottom {
      bottom: -34px;
    }

    .reviews-content {
      padding: 64px 1.25rem 72px;
    }

    .reviews-heading {
      margin-bottom: 34px;
    }

    .reviews-heading h2 {
      font-size: clamp(3.8rem, 15vw, 5.8rem);
    }

    .review-board {
      width: min(430px, 92vw);
      display: grid;
      gap: 1.35rem;
    }

    .review-grid {
      display: none;
    }

    .review-set {
      position: static;
      display: none;
      gap: 1.35rem;
    }

    .review-set.active {
      display: grid;
    }

    .review-tag {
      position: relative;
      left: auto;
      top: auto;
      width: min(380px, 92vw);
      margin: 0 auto;
    }

    .review-copy {
      width: 72%;
      padding: 0 0.85rem;
    }

    .review-copy p {
      font-size: clamp(0.82rem, 3.7vw, 1.02rem);
    }

    .review-copy strong {
      font-size: clamp(0.58rem, 2.6vw, 0.72rem);
    }
  }
</style>

<script is:inline>
  (() => {
    const sets = Array.from(document.querySelectorAll("[data-review-set]"));
    const dots = Array.from(document.querySelectorAll("[data-review-dot]"));

    if (!sets.length || !dots.length) return;

    let activeIndex = 0;
    let intervalId = 0;

    function showSet(index) {
      activeIndex = index;

      sets.forEach((set, i) => {
        set.classList.toggle("active", i === activeIndex);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle("active", i === activeIndex);
      });
    }

    function startAutoSwitch() {
      intervalId = window.setInterval(() => {
        showSet((activeIndex + 1) % sets.length);
      }, 6500);
    }

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        showSet(index);
        window.clearInterval(intervalId);
        startAutoSwitch();
      });
    });

    showSet(activeIndex);
    startAutoSwitch();
  })();
</script>
