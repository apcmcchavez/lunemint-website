---
const devfolioLink = "#";
const instagramLink = "https://www.instagram.com/madeby.lunemint/";
const email = "lunemint.designs@gmail.com";
---

<footer class="footer" id="shop">
  <div class="footer-inner">
    <div class="footer-section other-links">
      <h2>Other Links</h2>

      <a href={devfolioLink} target="_blank" rel="noreferrer">
        <span class="footer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path
              d="M12 4.5c.9 3.8 2.7 5.6 6.5 6.5-3.8.9-5.6 2.7-6.5 6.5-.9-3.8-2.7-5.6-6.5-6.5 3.8-.9 5.6-2.7 6.5-6.5Z"
            ></path>
          </svg>
        </span>
        <span>Devfolio</span>
      </a>
    </div>

    <div class="footer-section contact-details">
      <h2>Contact Details</h2>

      <a href={instagramLink} target="_blank" rel="noreferrer">
        <span class="footer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="5" y="5" width="14" height="14" rx="4"></rect>
            <circle cx="12" cy="12" r="3.15"></circle>
            <circle cx="16.3" cy="7.7" r="0.7"></circle>
          </svg>
        </span>
        <span>@madeby.lunemint</span>
      </a>

      <a href={`mailto:${email}`}>
        <span class="footer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <rect x="4.5" y="6.5" width="15" height="11" rx="1.5"></rect>
            <path d="M5.5 7.5 12 13l6.5-5.5"></path>
          </svg>
        </span>
        <span>{email}</span>
      </a>
    </div>

    <div class="footer-copyright">
      <p>© 2026 lunemint.</p>
      <p>All rights reserved.</p>
      <span>Made with ✦ by lunemint designs</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #6f2a7d;
    background-image:
      linear-gradient(90deg, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
      url("/images/patterns/footer-bg.png");
    background-size:
      42px 100%,
      100% 42px,
      190px 100%;
    background-position: center;
    color: #f8faf0;
    border-top: 5px solid rgba(244, 236, 196, 0.2);
    padding: 34px 5vw;
  }

  .footer-inner {
    width: min(1180px, 100%);
    margin: 0 auto;

    display: grid;
    grid-template-columns: 190px minmax(390px, 1fr) 300px;
    align-items: start;
    justify-content: space-between;
    column-gap: clamp(4rem, 8vw, 8rem);
  }

  .footer-section {
    display: grid;
    gap: 0.65rem;
    align-content: start;
    padding-top: 0.95rem;
  }

  .footer-section h2 {
    margin: 0 0 0.1rem;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #ffdc7e;
    white-space: nowrap;
  }

  .footer-section a {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;

    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.25;
    color: #ffffff;
    text-decoration: none;

    transition:
      color 180ms ease,
      transform 180ms ease;
  }

  .footer-section a:hover {
    color: #d03cd3;
    transform: translateX(4px);
  }

  .footer-icon {
    width: 25px;
    height: 25px;
    flex: 0 0 25px;

    display: inline-grid;
    place-items: center;

    color: #d9c4ff;
  }

  .footer-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .footer-copyright {
    align-self: center;
    justify-self: end;
    width: 100%;
    max-width: 285px;
    padding: 1.05rem 1.2rem;
    border-radius: 18px;

    background: linear-gradient(
      135deg,
      rgba(247, 255, 234, 0.18),
      rgba(247, 255, 234, 0.08)
    );
    border: 1px solid rgba(247, 255, 234, 0.25);
    box-shadow:
      8px 8px 0 rgba(36, 20, 47, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    backdrop-filter: blur(10px);
  }

  .footer-copyright p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1.35;
    color: #f8faf0;
  }

  .footer-copyright span {
    display: block;
    margin-top: 0.45rem;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 700;
    line-height: 1.35;
    color: rgba(248, 250, 240, 0.74);
  }

  @media (max-width: 900px) {
    .footer {
      padding: 34px 1.4rem;
      text-align: center;
    }

    .footer-inner {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: 1.7rem;
    }

    .footer-section {
      justify-items: center;
    }

    .footer-section a {
      justify-content: center;
    }

    .footer-section a:hover {
      transform: translateY(-2px);
    }

    .footer-copyright {
      justify-self: center;
      text-align: center;
    }
  }
</style>
