---
const faqs = [
  {
    q: "How long does a project take?",
    a: "Most simple graphics take a few days. Larger decks, templates, or patterned sets may take longer depending on the details.",
  },
  {
    q: "How do I request a commission?",
    a: "Prepare your idea, deadline, references, and preferred style. Then contact Lunemint so the project can be reviewed.",
  },
  {
    q: "Do you make Canva graphics?",
    a: "Yes. Lunemint can create Canva posters, pubmats, social graphics, presentation decks, and templates.",
  },
  {
    q: "Can I request revisions?",
    a: "Yes. Revisions can be discussed depending on the scope of the commission.",
  },
  {
    q: "Do you accept rush projects?",
    a: "Rush projects depend on availability and project complexity.",
  },
];
---

<section id="faq" class="faq-section">
  <div class="faq-heading">
    <p>FAQ</p>
    <h2>Frequently Asked Questions</h2>
    <span>Everything you need to know before placing an order</span>
  </div>

  <div class="faq-layout">
    <div class="faq-list">
      {
        faqs.map((faq) => (
          <details>
            <summary>
              <span>{faq.q}</span>
              <b>+</b>
            </summary>
            <p>{faq.a}</p>
          </details>
        ))
      }
    </div>

    <aside class="contact-card">
      <h3>Still have questions<span class="faq-question-mark">?</span></h3>
      <p>
        Message me directly — I’m happy to help before you place your
        commission.
      </p>
      <a href="#about">Contact Me</a>
    </aside>
  </div>
</section>

<style>
  .faq-section {
    padding: 120px clamp(1rem, 5vw, 5rem) 104px;
    background-color: #c9b8d5;
    background-image:
      linear-gradient(45deg, rgba(255, 255, 255, 0.32) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(255, 255, 255, 0.32) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(255, 255, 255, 0.32) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(255, 255, 255, 0.32) 75%);
    background-size: 260px 260px;
    background-position:
      0 0,
      0 130px,
      130px -130px,
      -130px 0;
  }

  .faq-heading {
    text-align: center;
    margin-bottom: 46px;
  }

  .faq-layout {
    margin-top: 18px;
  }

  .faq-heading p,
  .faq-heading span {
    display: block;
    margin: 0;
    font-family: var(--font-body);
    font-size: 20px;
    text-transform: uppercase;
    color: #8e36a1;
  }

  .faq-heading h2 {
    margin: 8px 0 14px;
    font-family: var(--font-sergio);
    font-size: clamp(2.8rem, 5.5vw, 4.8rem);
    font-weight: 900;
    line-height: 1;
    color: #40098c;
  }

  .faq-layout {
    width: min(1350px, 100%);
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.75fr) minmax(260px, 1fr);
    gap: 44px;
    align-items: start;
  }

  .faq-list {
    display: grid;
    gap: 20px;
    width: 100%;
  }

  details {
    background: #f7ffea;
    box-shadow: 8px 8px 0 rgba(41, 0, 135, 0.16);
    width: 100%;
    margin: 0;
    padding: 0;
  }

  summary {
    min-height: 64px;
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0 30px;
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 800;
    color: #99acff;
  }

  summary span {
    flex: 1;
    min-width: 0;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary b {
    display: grid;
    place-items: center;
    width: 27px;
    height: 27px;
    border-radius: 50%;
    background: #a330a5;
    color: white;
  }

  details[open] summary b {
    transform: rotate(45deg);
  }

  details p {
    margin: 0;
    padding: 0 26px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 420ms ease,
      opacity 360ms ease,
      padding-bottom 360ms ease;
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: #290087;
  }

  details[open] p {
    max-height: 400px;
    padding-bottom: 22px;
    opacity: 1;
  }

  .contact-card {
    min-height: 170px;
    padding: 28px 24px;
    background: #290087;
    color: white;
    text-align: center;
    box-shadow: 10px 10px 0 rgba(41, 0, 135, 0.22);
    max-width: 100%;
  }

  .contact-card h3 {
    margin: 0 0 12px;
    font-family: var(--font-sergio);
    font-size: 23px;
    color: #f4ecc4;
  }

  .faq-question-mark {
    font-family: "Montserrat", Arial, sans-serif;
    font-weight: 700;
    font-style: normal;
    font-variant-ligatures: none;
    font-feature-settings:
      "liga" 0,
      "clig" 0;
    margin-left: 0.35rem;
  }

  .contact-card p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.75;
    color: #99acff;
  }

  .contact-card a {
    display: inline-flex;
    margin-top: 18px;
    padding: 12px 24px;
    background: #a330a5;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 800;
    color: #f8faf0;
    transition:
      background 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .contact-card a:hover {
    background: #8f56b8;
    color: #290087;
    transform: translateY(-1px);
  }

  @media (max-width: 980px) {
    .faq-layout {
      grid-template-columns: 1fr;
    }

    details {
      width: 100%;
      margin-left: 0;
      padding-left: 24px;
      padding-right: 24px;
    }
  }
</style>
