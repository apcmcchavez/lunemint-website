<style>
  .notice-bar {
    background: var(--main-purple);
    color: var(--cream);
    overflow: hidden;
    white-space: nowrap;
    padding: 8px 0;
    position: relative;
    z-index: 100;
  }

  .notice-track {
    display: inline-flex;
    gap: 0;
    width: max-content;
    animation: marquee 22s linear infinite;
  }

  .notice-group {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 0 40px;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream);
  }

  .notice-group img,
  .notice-group .star {
    color: var(--yellow);
    font-size: 14px;
    width: 14px;
    height: 14px;
    object-fit: contain;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
</style>

<script>
  (() => {
    const track = document.querySelector<HTMLElement>(".notice-track");
    const container = track?.parentElement as HTMLElement | null;

    if (!track || !container) return;

    const safeTrack = track;
    const safeContainer = container;
    const originalHTML = safeTrack.innerHTML;

    function duplicateUntilWide() {
      safeTrack.innerHTML = originalHTML;

      let safety = 0;

      while (
        safeTrack.scrollWidth < safeContainer.clientWidth * 2 &&
        safety < 12
      ) {
        safeTrack.insertAdjacentHTML("beforeend", originalHTML);
        safety++;
      }
    }

    window.setTimeout(duplicateUntilWide, 50);

    window.addEventListener("resize", () => {
      window.setTimeout(duplicateUntilWide, 120);
    });
  })();
</script>
