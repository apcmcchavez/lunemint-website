---

<section id="portfolio" class="previous-works">
  <img
    class="top-strip"
    src="/images/patterns/plaid-flower-strip.png"
    alt=""
    aria-hidden="true"
  />

  <div class="works-inner">
    <img
      class="works-title"
      src="/images/portfolio/previous-works-title.svg"
      alt="Previous Works"
    />

    <div class="polaroid-scroller" aria-label="Previous works carousel">
      {
        works.map((work, index) => (
          <article class={`polaroid tilt-${(index % 4) + 1}`}>
            <div class="polaroid-art">
              <img src={work.image} alt={work.title} />
              <div class="polaroid-overlay" />
            </div>

            <div class="polaroid-text">
              <h3>{work.title}</h3>
              <p>{work.description}</p>
              <a href={work.link} target="_blank" rel="noopener noreferrer">
                View folder →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  :global(body) {
    overflow-x: hidden;
  }

  .previous-works {
    position: relative;
    overflow: hidden;
    background-color: #773db2;
    background-image: url("/images/patterns/purple-gridlines-bg.webp");
    background-size: cover;
    background-position: center;
  }

  .top-strip {
    width: 100%;
    height: 72px;
    object-fit: cover;
    object-position: center;
    display: block;
    border-top: 1px solid #d8d5ff;
    border-bottom: 1px solid #d8d5ff;
    box-shadow: inset 0 6px 0 rgba(255, 255, 255, 0.03);
  }

  .works-inner {
    padding: 80px 0 92px;
  }

  .works-title {
    display: block;
    width: min(980px, 88%);
    margin: 0 auto 48px;
    max-width: 1100px;
  }

  .polaroid-scroller {
    display: flex;
    gap: 44px;
    overflow-x: auto;
    overflow-y: visible;
    scroll-behavior: smooth;
    scroll-snap-type: x proximity;
    overscroll-behavior-x: contain;

    padding: 28px max(48px, calc((100vw - 1280px) / 2)) 58px;

    scrollbar-width: none;
    -ms-overflow-style: none;
    cursor: grab;
  }

  .polaroid-scroller:hover {
    cursor: grab;
  }

  .polaroid-scroller.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
  }

  .polaroid-scroller::-webkit-scrollbar {
    display: none;
  }

  .polaroid {
    flex: 0 0 340px;
    width: 340px;
    min-height: 480px;
    scroll-snap-align: start;

    background: white;
    padding: 18px 18px 22px;
    box-shadow: 0 12px 0 rgba(41, 0, 135, 0.42);

    transition:
      transform 280ms ease,
      box-shadow 280ms ease;
  }

  .polaroid:hover {
    box-shadow: 0 16px 0 rgba(41, 0, 135, 0.46);
  }

  .tilt-1 {
    transform: rotate(-3deg);
  }

  .tilt-1:hover {
    transform: rotate(-3deg) translateY(-8px);
  }

  .tilt-2 {
    transform: rotate(2deg) translateY(-12px);
  }

  .tilt-2:hover {
    transform: rotate(2deg) translateY(-20px);
  }

  .tilt-3 {
    transform: rotate(-2deg);
  }

  .tilt-3:hover {
    transform: rotate(-2deg) translateY(-8px);
  }

  .tilt-4 {
    transform: rotate(4deg);
  }

  .tilt-4:hover {
    transform: rotate(4deg) translateY(-8px);
  }

  .polaroid-art {
    width: 100%;
    height: 340px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(#c7efff, #eefcff);
  }

  .polaroid-art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .polaroid-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(0, 0, 0, 0.12) 100%
    );
  }

  .polaroid-text {
    padding-top: 12px;
  }

  .polaroid-text h3 {
    margin: 0;
    font-family: var(--font-playlist);
    font-size: 28px;
    font-style: italic;
    color: #40098c;
    line-height: 1;
  }

  .polaroid-text p {
    margin: 10px 0;
    max-width: 260px;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.4;
    color: #291750;
  }

  .polaroid-text a {
    display: inline-block;
    margin-top: 2px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: #a330a5;
    text-decoration: none;
    transition:
      color 220ms ease,
      transform 220ms ease;
  }

  .polaroid-text a:hover {
    color: #40098c;
    transform: translateX(4px);
  }

  @media (max-width: 850px) {
    .works-inner {
      padding: 64px 0 76px;
    }

    .works-title {
      margin-bottom: 32px;
    }

    .polaroid-scroller {
      gap: 28px;
      padding: 24px 28px 48px;
    }

    .polaroid {
      flex-basis: 280px;
      width: 280px;
      min-height: 410px;
    }

    .polaroid-art {
      height: 280px;
    }
  }
</style>

<script>
  (() => {
    const foundScroller =
      document.querySelector<HTMLElement>(".polaroid-scroller");

    if (!foundScroller) return;

    const scroller: HTMLElement = foundScroller;

    let targetScrollLeft: number = scroller.scrollLeft;
    let currentScrollLeft: number = scroller.scrollLeft;
    let animationFrame: number = 0;

    function clamp(value: number, min: number, max: number): number {
      return Math.min(Math.max(value, min), max);
    }

    function maxScrollLeft(): number {
      return Math.max(0, scroller.scrollWidth - scroller.clientWidth);
    }

    function smoothStep(): void {
      currentScrollLeft += (targetScrollLeft - currentScrollLeft) * 0.14;
      scroller.scrollLeft = currentScrollLeft;

      if (Math.abs(targetScrollLeft - currentScrollLeft) > 0.5) {
        animationFrame = window.requestAnimationFrame(smoothStep);
      } else {
        scroller.scrollLeft = targetScrollLeft;
        animationFrame = 0;
      }
    }

    function startSmoothScroll(): void {
      if (animationFrame) return;
      animationFrame = window.requestAnimationFrame(smoothStep);
    }

    scroller.addEventListener(
      "wheel",
      (event: WheelEvent) => {
        const canScrollHorizontally =
          scroller.scrollWidth > scroller.clientWidth;

        if (!canScrollHorizontally) return;

        const scrollingDown = event.deltaY > 0;
        const scrollingUp = event.deltaY < 0;
        const atStart = scroller.scrollLeft <= 0;
        const atEnd = scroller.scrollLeft >= maxScrollLeft() - 1;

        if ((scrollingUp && atStart) || (scrollingDown && atEnd)) {
          return;
        }

        event.preventDefault();

        const wheelAmount =
          Math.abs(event.deltaX) > Math.abs(event.deltaY)
            ? event.deltaX
            : event.deltaY;

        targetScrollLeft = clamp(
          targetScrollLeft + wheelAmount * 0.9,
          0,
          maxScrollLeft(),
        );

        startSmoothScroll();
      },
      { passive: false },
    );

    let isDragging: boolean = false;
    let startX: number = 0;
    let startScrollLeft: number = 0;

    scroller.addEventListener("pointerdown", (event: PointerEvent) => {
      isDragging = true;
      startX = event.clientX;
      startScrollLeft = scroller.scrollLeft;
      targetScrollLeft = scroller.scrollLeft;
      currentScrollLeft = scroller.scrollLeft;

      scroller.classList.add("is-dragging");
      scroller.setPointerCapture(event.pointerId);
    });

    scroller.addEventListener("pointermove", (event: PointerEvent) => {
      if (!isDragging) return;

      const distance = event.clientX - startX;
      scroller.scrollLeft = startScrollLeft - distance;
      targetScrollLeft = scroller.scrollLeft;
      currentScrollLeft = scroller.scrollLeft;
    });

    function stopDragging(event: PointerEvent): void {
      isDragging = false;
      scroller.classList.remove("is-dragging");

      try {
        scroller.releasePointerCapture(event.pointerId);
      } catch {
        /* pointer capture may already be released */
      }
    }

    scroller.addEventListener("pointerup", (event: PointerEvent) => {
      stopDragging(event);
    });

    scroller.addEventListener("pointercancel", (event: PointerEvent) => {
      stopDragging(event);
    });

    window.addEventListener("resize", () => {
      targetScrollLeft = clamp(scroller.scrollLeft, 0, maxScrollLeft());
      currentScrollLeft = targetScrollLeft;
    });
  })();
</script>
