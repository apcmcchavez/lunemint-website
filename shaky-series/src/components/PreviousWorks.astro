    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/hero/stars-hero-bg.webp",
  },
  {
    title: "Pastel Palette",
    description:
      "Moodboards, graphics, and creative visual sets for dreamy vibes.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/patterns/what-i-offer-bg.png",
  },
  {
    title: "Mini Template",
    description: "Canva templates for school, orgs, and small brands.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/about/about-me-stars-bg.png",
  },
  {
    title: "Presentation Decks",
    description: "Clean, polished decks and slide layouts for school and work.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/hero/watercolor-mountains-hero-bg.webp",
  },
  {
    title: "Resume Templates",
    description: "Polished resumes with a soft, modern visual identity.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/reviews/customer-reviews-grid.png",
  },
  {
    title: "Patterned Designs",
    description: "Reusable patterns and graphics for print and digital pieces.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/patterns/plaid-flower-strip.png",
  },
  {
    title: "Birthday Collage",
    description:
      "Custom theme collages for gifts, socials, and personal projects.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/patterns/purple-gridlines-bg.webp",
  },
  {
    title: "Study Planner",
    description:
      "Organized planner templates for students who want cute productivity.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/patterns/what-i-offer-bg.png",
  },
  {
    title: "Workshop Poster",
    description:
      "Eye-catching posters designed for school events and creative workshops.",
    link: "https://drive.google.com/drive/folders/YOUR_FOLDER_ID_HERE",
    image: "/images/about/about-me-stars-bg.png",
  },
